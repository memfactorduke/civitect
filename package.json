{
  "name": "civitect",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "wall": "depcruise packages --config .dependency-cruiser.cjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "gate:golden": "node scripts/ci/golden-gate.mjs",
    "gate:balance": "node scripts/ci/balance-gate.mjs",
    "gate:perf": "node scripts/ci/perf-gate.mjs",
    "gate:assets": "node scripts/ci/asset-gate.mjs",
    "verify": "pnpm lint && pnpm wall && pnpm typecheck && pnpm test && pnpm gate:golden && pnpm gate:balance && pnpm gate:perf && pnpm gate:assets"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "dependency-cruiser": "^16.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
