{
  "name": "@civitect/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "golden": "vitest run --config vitest.golden.config.ts",
    "perf": "vitest run --config vitest.perf.config.ts",
    "bless": "BLESS=1 vitest run --config vitest.golden.config.ts",
    "smoke": "playwright test",
    "cross-check": "playwright test --config playwright.cross-check.config.ts",
    "balance": "vitest run --config vitest.balance.config.ts",
    "archetypes": "vitest run --config vitest.archetypes.config.ts",
    "diagnostics": "vitest run --config vitest.diagnostics.config.ts"
  },
  "dependencies": {
    "@civitect/protocol": "workspace:*",
    "@civitect/renderer": "workspace:*",
    "@civitect/sim": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
